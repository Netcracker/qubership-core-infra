<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Qubership Core — LTS Versions</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
           font-size: 14px; background: #f6f8fa; color: #24292f; }
    header { background: #24292f; color: #fff; padding: 16px 24px;
             display: flex; align-items: center; justify-content: space-between; }
    header h1 { font-size: 18px; font-weight: 600; }
    header span { font-size: 12px; opacity: 0.6; }

    /* ── Tabs ── */
    .tabs-root { display: flex; flex-direction: column; }
    .tabs-root input[type="radio"] { display: none; }
    .tab-bar { display: flex; padding: 0 24px; background: #fff;
               border-bottom: 1px solid #d0d7de; gap: 0; }
    .tab-bar label { padding: 12px 20px; cursor: pointer; font-weight: 500;
                     border-bottom: 3px solid transparent; margin-bottom: -1px;
                     color: #57606a; transition: color .15s, border-color .15s; }
    .tab-bar label:hover { color: #24292f; }
    #tab-java-libs:checked     ~ .tab-bar label[for="tab-java-libs"],
    #tab-java-services:checked ~ .tab-bar label[for="tab-java-services"],
    #tab-go-libs:checked       ~ .tab-bar label[for="tab-go-libs"],
    #tab-go-services:checked   ~ .tab-bar label[for="tab-go-services"] {
      color: #0969da; border-bottom-color: #0969da; }
    .tab-pane { display: none; }
    #tab-java-libs:checked     ~ .tab-pane-java-libs     { display: block; }
    #tab-java-services:checked ~ .tab-pane-java-services { display: block; }
    #tab-go-libs:checked       ~ .tab-pane-go-libs       { display: block; }
    #tab-go-services:checked   ~ .tab-pane-go-services   { display: block; }

    /* ── Table ── */
    .container { padding: 24px; overflow-x: auto; }
    table { border-collapse: collapse; width: 100%; background: #fff;
            border: 1px solid #d0d7de; border-radius: 6px; overflow: hidden; }
    th { background: #f6f8fa; border-bottom: 2px solid #d0d7de; padding: 10px 16px;
         text-align: left; font-weight: 600; white-space: nowrap;
         position: sticky; top: 0; z-index: 1; }
    th.ver { text-align: center; }
    th.snap-th { background: #fff8e1; }
    td { padding: 7px 16px; border-bottom: 1px solid #eaeef2; }
    tr.ms td { border-top: 2px solid #d0d7de; }
    td.mod { font-weight: 600; border-right: 1px solid #d0d7de;
             vertical-align: top; white-space: nowrap; }
    td.art { font-family: 'SFMono-Regular', Consolas, monospace; font-size: 13px; }
    td.ver { text-align: center; font-family: 'SFMono-Regular', Consolas, monospace;
             font-size: 13px; }
    td.ver span { background: #ddf4ff; color: #0969da; border-radius: 12px;
                  padding: 2px 10px; display: inline-block; }
    td.snap span { background: #fff3cd; color: #9a6700; border-radius: 12px;
                   padding: 2px 10px; display: inline-block; }
    td.miss { text-align: center; color: #8c959f; }
    a.dl { display: inline-block; margin-top: 4px; font-size: 11px; padding: 2px 8px;
           background: #0969da; color: #fff; border-radius: 4px; text-decoration: none; }
    a.dl:hover { background: #0550ae; }
  </style>
</head>
<body>
<header>
  <h1>Qubership Core — LTS Versions</h1>
  <span>Generated: {{ ts }}</span>
</header>

{% set tab_count = (java_libs is not none) | int + (java_services is not none) | int + (go_libs is not none) | int + (go_services is not none) | int %}
{% if tab_count > 1 %}
<div class="tabs-root">
  {% if java_libs     %}<input type="radio" id="tab-java-libs"     name="tab" checked>{% endif %}
  {% if java_services %}<input type="radio" id="tab-java-services" name="tab"{% if not java_libs %} checked{% endif %}>{% endif %}
  {% if go_libs       %}<input type="radio" id="tab-go-libs"       name="tab"{% if not java_libs and not java_services %} checked{% endif %}>{% endif %}
  {% if go_services   %}<input type="radio" id="tab-go-services"   name="tab"{% if not java_libs and not java_services and not go_libs %} checked{% endif %}>{% endif %}
  <nav class="tab-bar">
    {% if java_libs     %}<label for="tab-java-libs">Java Libs</label>{% endif %}
    {% if java_services %}<label for="tab-java-services">Java Services</label>{% endif %}
    {% if go_libs       %}<label for="tab-go-libs">Go Libs</label>{% endif %}
    {% if go_services   %}<label for="tab-go-services">Go Services</label>{% endif %}
  </nav>
  {% if java_libs %}
  <div class="tab-pane tab-pane-java-libs">
    {% with java = java_libs %}{% include 'java-table.html.j2' %}{% endwith %}
  </div>
  {% endif %}
  {% if java_services %}
  <div class="tab-pane tab-pane-java-services">
    {% with java = java_services %}{% include 'java-table.html.j2' %}{% endwith %}
  </div>
  {% endif %}
  {% if go_libs %}
  <div class="tab-pane tab-pane-go-libs">
    {% with go = go_libs %}{% include 'go-table.html.j2' %}{% endwith %}
  </div>
  {% endif %}
  {% if go_services %}
  <div class="tab-pane tab-pane-go-services">
    {% with go = go_services %}{% include 'go-table.html.j2' %}{% endwith %}
  </div>
  {% endif %}
</div>
{% else %}
  {% if java_libs     %}{% with java = java_libs     %}{% include 'java-table.html.j2' %}{% endwith %}{% endif %}
  {% if java_services %}{% with java = java_services %}{% include 'java-table.html.j2' %}{% endwith %}{% endif %}
  {% if go_libs       %}{% with go = go_libs         %}{% include 'go-table.html.j2'   %}{% endwith %}{% endif %}
  {% if go_services   %}{% with go = go_services     %}{% include 'go-table.html.j2'   %}{% endwith %}{% endif %}
{% endif %}

</body>
</html>
