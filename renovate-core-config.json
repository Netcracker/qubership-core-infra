{
  "assignAutomerge" : true,
  "assigneesFromCodeOwners" : true,
  "autodiscover" : false,
  "binarySource" : "install",
  "branchConcurrentLimit" : 25,
  "branchPrefix" : "renovate-main/",
  "enabled" : true,
  "globalExtends" : [ ":ignoreModulesAndTests", ":dependencyDashboard" ],
  "hostRules" : [ {
    "hostType" : "maven",
    "matchHost" : "maven.pkg.github.com",
    "token" : "{{ secrets.renovation_bot_private_packages_read }}"
  } ],
  "labels" : [ "renovate:core", "branch:main" ],
  "packageRules" : [ {
    "matchManagers" : [ "maven" ],
    "matchPackageNames" : [ "/.*/" ],
    "addLabels" : [ "manager:maven" ]
  }, {
    "matchManagers" : [ "dockerfile" ],
    "matchPackageNames" : [ "/.*/" ],
    "addLabels" : [ "manager:docker" ]
  }, {
    "matchManagers" : [ "gomod" ],
    "matchPackageNames" : [ "/.*/" ],
    "addLabels" : [ "manager:go" ]
  }, {
    "matchManagers" : [ "github-actions" ],
    "matchPackageNames" : [ "/.*/" ],
    "addLabels" : [ "manager:github-actions" ]
  }, {
    "matchPackageNames" : [ "/.*/" ],
    "allowedVersions" : "!/.*(redhat|composite|groovyless|jboss|atlassian|preview|does-not-exist|-SNAPSHOT).*/"
  }, {
    "matchDatasources" : [ "maven" ],
    "registryUrls" : [ "https://repo.maven.apache.org/maven2", "https://maven.pkg.github.com/netcracker/*" ]
  }, {
    "matchDatasources" : [ "docker" ],
    "matchPackageNames" : [ "/.+/netcracker/qubership-java-base.*/" ],
    "versioning" : "regex:^(?<compatibility>\\d+)-alpine-(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)$"
  }, {
    "matchManagers" : [ "maven" ],
    "groupName" : "maven",
    "groupSlug" : "maven",
    "addLabels" : [ "group:maven" ]
  }, {
    "matchManagers" : [ "gomod" ],
    "matchUpdateTypes" : [ "major" ],
    "groupName" : "go-major",
    "groupSlug" : "go-major",
    "addLabels" : [ "group:go" ]
  }, {
    "matchManagers" : [ "gomod" ],
    "matchUpdateTypes" : [ "minor" ],
    "groupName" : "go-minor",
    "groupSlug" : "go-minor",
    "addLabels" : [ "group:go" ]
  }, {
    "matchManagers" : [ "gomod" ],
    "matchUpdateTypes" : [ "patch" ],
    "groupName" : "go-patch",
    "groupSlug" : "go-patch",
    "addLabels" : [ "group:go" ]
  }, {
    "matchManagers" : [ "gomod" ],
    "matchUpdateTypes" : [ "digest" ],
    "groupName" : "go-digest",
    "groupSlug" : "go-digest",
    "addLabels" : [ "group:go" ]
  }, {
    "matchManagers" : [ "gomod" ],
    "matchPackageNames" : [ "/(.*netcracker.*)/" ],
    "matchUpdateTypes" : [ "major" ],
    "groupName" : "go-netcracker-major",
    "groupSlug" : "go-netcracker-major",
    "addLabels" : [ "group:go-netcracker" ]
  }, {
    "matchManagers" : [ "gomod" ],
    "matchPackageNames" : [ "/(.*netcracker.*)/" ],
    "matchUpdateTypes" : [ "minor" ],
    "groupName" : "go-netcracker-minor",
    "groupSlug" : "go-netcracker-minor",
    "addLabels" : [ "group:go-netcracker" ]
  }, {
    "matchManagers" : [ "gomod" ],
    "matchPackageNames" : [ "/(.*netcracker.*)/" ],
    "matchUpdateTypes" : [ "patch" ],
    "groupName" : "go-netcracker-patch",
    "groupSlug" : "go-netcracker-patch",
    "addLabels" : [ "group:go-netcracker" ]
  }, {
    "matchManagers" : [ "gomod" ],
    "matchPackageNames" : [ "/(.*netcracker.*)/" ],
    "matchUpdateTypes" : [ "digest" ],
    "groupName" : "go-netcracker-digest",
    "groupSlug" : "go-netcracker-digest",
    "addLabels" : [ "group:go-netcracker" ]
  }, {
    "matchManagers" : [ "gomod" ],
    "matchPackageNames" : [ "github.com/valyala/fasthttp" ],
    "matchNewValue" : [ "v1.70.0" ],
    "groupName" : "go-fasthttp",
    "groupSlug" : "go-fasthttp",
    "addLabels" : [ "group:go" ]
  }, {
    "matchManagers" : [ "gomod" ],
    "matchDepNames" : [ "go" ],
    "matchDepTypes" : [ "golang" ],
    "rangeStrategy" : "bump",
    "addLabels" : [ "group:go-version" ]
  }, {
    "matchManagers" : [ "github-actions" ],
    "groupName" : "github-actions"
  }, {
    "matchPackageNames" : [ "/^com\\.netcracker\\./" ],
    "groupName" : "netcracker",
    "groupSlug" : "netcracker",
    "addLabels" : [ "group:netcracker" ]
  }, {
    "matchPackageNames" : [ "org.apache.commons:commons-lang3" ],
    "groupName" : "maven",
    "allowedVersions" : "/^3.20.0$/"
