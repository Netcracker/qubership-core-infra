  "platform" : "github",
  "platformAutomerge" : true,
  "postUpdateOptions" : [ "gomodUpdateImportPaths", "gomodTidy" ],
  "prConcurrentLimit" : 25,
  "prCreation" : "immediate",
  "prHourlyLimit" : 5,
  "printConfig" : true,
  "pruneStaleBranches" : true,
  "rebaseWhen" : "behind-base-branch",
  "recreateWhen" : "always",
  "repositories" : [ ],
  "reviewersFromCodeOwners" : true,
  "vulnerabilityAlerts" : {
